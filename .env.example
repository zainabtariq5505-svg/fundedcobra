# ─────────────────────────────────────────────────────────────
#  FundedCobra — Complete Project Environment Variables
# ─────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.

# ════════════════════════════════════════════════════════════
#  DASHBOARD (Next.js + Vercel)
# ════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=

# ── NextAuth ─────────────────────────────────────────────────
NEXTAUTH_SECRET=your_super_secret_string_here
NEXTAUTH_URL=http://localhost:3000

# ── Discord OAuth ────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=

# ── Admin Account ────────────────────────────────────────────
ADMIN_EMAIL=admin@fundedcobra.com
ADMIN_INITIAL_PASSWORD=ChangeThisPassword123!
ADMIN_NAME="FundedCobra Admin"

# ════════════════════════════════════════════════════════════
#  DISCORD BOT (Node.js)
# ════════════════════════════════════════════════════════════

# ── Discord ──────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
# Optional: Set to your server ID to register slash commands instantly (dev mode)
# Leave blank to register globally (takes ~1 hour)
DISCORD_GUILD_ID=

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# Chat model — gpt-4o-mini (fast/cheap) or gpt-4o (best quality)
OPENAI_CHAT_MODEL=gpt-4o-mini
# Embedding model — text-embedding-3-small is fast and cheap
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Bot Database ────────────────────────────────────────────
# Pick ONE of the three options below:

# Option 1 — SQLite (default, no server needed)
DATABASE_URL=file:./data/fundedcobra.db

# Option 2 — MongoDB Atlas (cloud) or local MongoDB
# DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0
# DATABASE_URL=mongodb://localhost:27017/fundedcobra

# Option 3 — PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/fundedcobra

# After changing database provider, run:
#   npm run db:use-mongo   (switch schema to MongoDB, then npm run db:push)
#   npm run db:use-sqlite  (switch schema back to SQLite, then npm run db:migrate)

# ── Bot Settings ─────────────────────────────────────────────
BOT_PREFIX=!
# Optional: Discord role ID for admin access (in addition to ADMINISTRATOR permission)
ADMIN_ROLE_ID=

# ── Scraper Settings ─────────────────────────────────────────
# Comma-separated list of allowed domains for URL imports
ALLOWED_DOMAINS=fundedcobra.com,www.fundedcobra.com
# Maximum pages to scrape per import operation
MAX_SCRAPE_PAGES=20

# ── RAG Settings ───────────────────────────────────────────
# Number of top chunks to retrieve per query
RAG_TOP_K=5
# Cosine similarity threshold: ≥ this → high confidence (official rule)
RAG_CONFIDENCE_THRESHOLD=0.75
# Cosine similarity threshold: ≥ this → medium confidence (cautious)
RAG_MIN_CONFIDENCE=0.40

# ── Rate Limiting ────────────────────────────────────────────
COOLDOWN_SECONDS=3

# ── Environment ──────────────────────────────────────────────
NODE_ENV=production
