model SocialNotificationLog {
  id              String    @id @default(cuid())
  guildId         String
  socialAccountId String
  platform        String
  externalPostId  String?
  url             String?
  status          String
  errorMessage    String?
  postedAt        DateTime?
  createdAt       DateTime  @default(now())
}

model TicketSettings {
  id                  String   @id @default(cuid())
  guildId             String   @unique
  categoryId          String?
  logChannelId        String?
  aiEnabledByDefault  Boolean  @default(true)
  reEnableAiOnUnclaim Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TicketClaimLog {
  id                String   @id @default(cuid())
  guildId           String
  ticketId          String
  claimedById       String
  claimedByUsername String
