model TicketTranscript {
  id           String   @id @default(cuid())
  guildId      String
  ticketId     String
  channelId    String
  userId       String
  username     String
  closedBy     String?
  messageCount Int      @default(0)
  htmlFilePath String?
  txtFilePath  String?
  url          String?
  createdAt    DateTime @default(now())
}
